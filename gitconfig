[include]
  path = ~/.gitconfig.local
[includeIf "gitdir:~/work/"]
  path = ~/.gitconfig.work
[url "git@github.com:"]
  insteadOf = "https://github.com/"
[user]
  name = Grant Welch
  useConfigOnly = true
[core]
  editor = /usr/bin/env vim
  excludesfile = ~/.gitignore
[push]
  default = current
  followTags = true
[color]
  ui = auto
[color "decorate"]
  branch = bold blue
  remoteBranch = red
  tag = ul dim cyan
  stash = reverse bold green
  HEAD = ul green
[color "branch"]
  current = reverse bold yellow
  local = yellow
  remote = red
[color "diff"]
  meta = yellow bold
  frag = magenta bold
  old = red bold
  new = green bold
  whitespace = red reverse
[color "grep"]
  filename = yellow bold
  linenumber = blue
[status]
  short = true
  branch = true
[diff]
  tool = vimdiff
  algorithm = patience
  mnemonicPrefix = true
  wsErrorHighlight = all
  colorMoved = default
  ignoreSubmodules = dirty
[difftool]
  prompt = false
[merge]
  tool = vimdiff
	conflictStyle = diff3
[mergetool]
  prompt = false
[rerere]
  enabled = true
[alias]
  aa = add -AN
  ap = add -p
  br = branch
  ci = commit
  co = checkout
  cp = cherry-pick
  dc = "!git diff --stat ${1:-HEAD} #"
  todo = "!git grep TODO -- $GIT_PREFIX | cut -d: -f1 | uniq -c #"
  st = status
  up = pull --rebase --recurse-submodules=yes
  update = pull --rebase --recurse-submodules=yes
  amend = commit --amend --no-edit --reset-author
  reword = commit --amend --reset-author -v
  gg = grep -EIn --break --heading
  type = cat-file -t
  dump = cat-file -p
  latest = cat-file -p HEAD
  logs = log --stat --format=fuller
  ll = log --stat --patch --format=fuller
  a = log --pretty=format:\"%C(auto)%h -%d %s %C(green)(%cd) %C(bold blue)%aN <%aE>\" --all
  p = log --pretty=format:\"%C(auto)%h -%d %s %C(green)(%cd) %C(bold blue)%aN <%aE>\" 
  bip = bisect view --graph --pretty=format:\"%C(auto)%h -%d %s %C(green)(%cd) %C(bold blue)%aN <%aE>\"
  u = log --pretty=format:\"%C(auto)%h -%d %s %C(green)(%cd) %C(bold blue)%aN <%aE>\" @{u}
  bleach = clean -ffdx
  dryclean = clean -ndx
  uncommit = reset HEAD^
  nuke = reset --hard --
  discard = checkout -f HEAD --
  unstage = reset HEAD --
  b = branch -vv
  r = remote -v
  refs-latest = for-each-ref --sort='authordate:iso8601' --format=' %(authordate:relative)%09%(refname:short)' refs/remotes
  hs = shortlog -nes --no-merges
  ignore = update-index --assume-unchanged
  unignore = update-index --no-assume-unchanged
  chk = add -n .
  conflicts = diff --name-only --diff-filter=U
  root = rev-parse --show-toplevel
  dir = rev-parse --git-dir
  udiff = diff @{u}
  pdiff = diff @{push}
  fixup = commit --fixup
  cm = cherry origin/HEAD
	bb = for-each-ref --format='%(if)%(HEAD)%(then)* %(color:reverse bold yellow)%(else)%(if)%(worktreepath)%(then)+ %(color:cyan)%(else) %(color:yellow)%(end)%(end)%(align:30,left)%(refname:lstrip=2)%(end)%(color:reset) %(objectname:short) %(if:notequals=*)%(HEAD)%(then)%(if)%(worktreepath)%(then)(%(color:cyan)%(worktreepath)%(color:reset)) %(end)%(end)%(if)%(upstream)%(then)[%(color: blue)%(upstream:short)%(color:reset)%(if)%(upstream:track)%(then): %(upstream:track,nobracket)%(end)] %(end)%(if)%(push:track)%(then)[%(color: green)%(push:short)%(color:reset): %(push:track,nobracket)] %(end)%(contents:subject)' refs/heads
	cs = diff --compact-summary --relative
	push-mkmr = push -o merge_request.create merge_request.assign='grant.w' merge_request.draft merge_request.squash
[fetch]
  output = compact
  prune = true
  pruneTags = true
[rebase]
  autostash = true
  autosquash = true
[transfer]
  fsckObjects = no
[commit]
  verbose = true
[sendemail]
  smtpserver = smtp.gmail.com
  smtpserverport = 587
  smtpencryption = tls
  smtpuser = gwelch925@gmail.com
  from = Grant Welch <gwelch925@gmail.com>
[filter "lfs"]
  required = true
  clean = git-lfs clean -- %f
  smudge = git-lfs smudge -- %f
  process = git-lfs filter-process
[advice]
	ignoredHook = false
	detachedHead = false
[init]
	defaultBranch = main
[credential]
	helper = 
